# .gitignore - Tell Git what NOT to track

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.env
venv/
env/
ENV/

# Data files (don't commit large data!)
*.xlsx
*.csv
*.xls
*.pkl
*.joblib

# Logs and outputs
logs/
*.log
experiment_log.json
catboost_log.json
*.pkl

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Config files - KEEP these!
!configs/
!configs/*.yaml
!configs/*.yml

# Only ignore sensitive/local configs
configs/*.local.yaml
configs/*.secret.yaml
configs/production.yaml
configs/*.private.yaml

# Test outputs
.htmlcov/
.coverage
.pytest_cache/