# .gitignore - Tell Git what NOT to track

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.env
venv/
env/
ENV/

# Data files (don't commit large data!)
*.xlsx
*.csv
*.xls
*.pkl
*.joblib

# Logs and outputs
logs/
*.log
experiment_log.json
catboost_log.json
*.pkl

# IDE files
.vscode/
.idea/
*.swp
*.swo

# configs - keep templates, ignore secrets
configs/
!configs/*.yaml              # Keep all YAMLs by default
configs/*.local.yaml         # Ignore local overrides
configs/*.secret.yaml        # Ignore secrets
configs/production.yaml       # Ignore production configs
configs/*.private.yaml       # Ignore private configs

# Test outputs
.htmlcov/
.coverage
.pytest_cache/